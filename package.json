    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "hpagent": "^1.2.0",
    "socket.io": "^4.7.2",
    "socks-proxy-agent": "^8.0.2",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  },
  "engines": {
